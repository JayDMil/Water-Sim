void DrawBox(const Bounds& b) {
    glEnable(GL_COLOR_MATERIAL);
    glColor3f(0.95f, 0.95f, 0.95f); // Solid ceramic white
    glBegin(GL_QUADS);

    // Bottom
    glNormal3f(0.0f, 1.0f, 0.0f);
    glVertex3f(b.minX, b.minY, b.minZ); glVertex3f(b.maxX, b.minY, b.minZ);
    glVertex3f(b.maxX, b.minY, b.maxZ); glVertex3f(b.minX, b.minY, b.maxZ);

    // Front
    glNormal3f(0.0f, 0.0f, -1.0f);
    glVertex3f(b.minX, b.minY, b.maxZ); glVertex3f(b.maxX, b.minY, b.maxZ);
    glVertex3f(b.maxX, b.maxY, b.maxZ); glVertex3f(b.minX, b.maxY, b.maxZ);

    // Back
    glNormal3f(0.0f, 0.0f, 1.0f);
    glVertex3f(b.maxX, b.minY, b.minZ); glVertex3f(b.minX, b.minY, b.minZ);
    glVertex3f(b.minX, b.maxY, b.minZ); glVertex3f(b.maxX, b.maxY, b.minZ);

    // Left
    glNormal3f(1.0f, 0.0f, 0.0f);
    glVertex3f(b.minX, b.minY, b.minZ); glVertex3f(b.minX, b.minY, b.maxZ);
    glVertex3f(b.minX, b.maxY, b.maxZ); glVertex3f(b.minX, b.maxY, b.minZ);

    // Right
    glNormal3f(-1.0f, 0.0f, 0.0f);
    glVertex3f(b.maxX, b.minY, b.maxZ); glVertex3f(b.maxX, b.minY, b.minZ);
    glVertex3f(b.maxX, b.maxY, b.minZ); glVertex3f(b.maxX, b.maxY, b.maxZ);

    glEnd();

    glDisable(GL_LIGHTING);
    glColor3f(0.5f, 0.5f, 0.5f);
    glBegin(GL_LINES);

    // Bottom
    glVertex3f(b.minX, b.minY, b.minZ); glVertex3f(b.maxX, b.minY, b.minZ);
    glVertex3f(b.maxX, b.minY, b.minZ); glVertex3f(b.maxX, b.minY, b.maxZ);
    glVertex3f(b.maxX, b.minY, b.maxZ); glVertex3f(b.minX, b.minY, b.maxZ);
    glVertex3f(b.minX, b.minY, b.maxZ); glVertex3f(b.minX, b.minY, b.minZ);

    // Top
    glVertex3f(b.minX, b.maxY, b.minZ); glVertex3f(b.maxX, b.maxY, b.minZ);
    glVertex3f(b.maxX, b.maxY, b.minZ); glVertex3f(b.maxX, b.maxY, b.maxZ);
    glVertex3f(b.maxX, b.maxY, b.maxZ); glVertex3f(b.minX, b.maxY, b.maxZ);
    glVertex3f(b.minX, b.maxY, b.maxZ); glVertex3f(b.minX, b.maxY, b.minZ);

    // Sides
    glVertex3f(b.minX, b.minY, b.minZ); glVertex3f(b.minX, b.maxY, b.minZ);
    glVertex3f(b.maxX, b.minY, b.minZ); glVertex3f(b.maxX, b.maxY, b.minZ);
    glVertex3f(b.maxX, b.minY, b.maxZ); glVertex3f(b.maxX, b.maxY, b.maxZ);
    glVertex3f(b.minX, b.minY, b.maxZ); glVertex3f(b.minX, b.maxY, b.maxZ);

    glEnd();
    glEnable(GL_LIGHTING);
}

void RenderSimulation() {
    if (!hDC_global) return;

    glClearColor(0.1f, 0.1f, 0.15f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);

    glLoadIdentity();
    // Free fly camera orientation mapping
    glRotatef(cameraAngleX, 1.0f, 0.0f, 0.0f);
    glRotatef(cameraAngleY, 0.0f, 1.0f, 0.0f);
    glTranslatef(-cameraPosX, -cameraPosY, -cameraPosZ);

    DrawBathroom();
    DrawShowerhead();

    // Draw Particles in world space
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE); // Additive blending for a more glowing fluid liquid look!
    glDepthMask(GL_FALSE); // Prevent particles from occluding each other sharply
    glDisable(GL_LIGHTING); // Remove 3D specular shading so overlapping particles fuse into a volume

    glColor4f(0.1f, 0.3f, 0.6f, 0.25f); // blue transparent

    for (const auto& p : particles) {
        glPushMatrix();
        glTranslatef(p.x, p.y, p.z);
        DrawSphere(PARTICLE_RADIUS * 1.8f * p.scale, 8, 8); // Scaled up to overlap more seamlessly
        glPopMatrix();
    }

    glEnable(GL_LIGHTING);
    glDepthMask(GL_TRUE);
    glDisable(GL_BLEND);

    // Draw Tub in local space
    glPushMatrix();
    glTranslatef(tubPosX, tubPosY, tubPosZ);
    glRotatef(tubAngleZ, 0.0f, 0.0f, 1.0f);
    glRotatef(tubAngleY, 0.0f, 1.0f, 0.0f);
    glRotatef(tubAngleX, 1.0f, 0.0f, 0.0f);
    DrawBox(container);
    glPopMatrix();

    // Draw Gizmo (World Space translation for simplicity)
    glDisable(GL_LIGHTING);
    glDisable(GL_DEPTH_TEST); // Draw on top
    glLineWidth(4.0f);
    if (gizmoMode == 0) {
        glBegin(GL_LINES);
        // X Axis (Red)
        glColor3f(activeGizmoAxis == 1 ? 1.0f : 0.6f, 0.0f, 0.0f);
        glVertex3f(tubPosX, tubPosY, tubPosZ); glVertex3f(tubPosX + 150.0f, tubPosY, tubPosZ);
        // Y Axis (Green)
        glColor3f(0.0f, activeGizmoAxis == 2 ? 1.0f : 0.6f, 0.0f);
        glVertex3f(tubPosX, tubPosY, tubPosZ); glVertex3f(tubPosX, tubPosY + 150.0f, tubPosZ);
        // Z Axis (Blue)
        glColor3f(0.0f, 0.0f, activeGizmoAxis == 3 ? 1.0f : 0.6f);
        glVertex3f(tubPosX, tubPosY, tubPosZ); glVertex3f(tubPosX, tubPosY, tubPosZ + 150.0f);
        glEnd();
    } else {
        for (int axis = 1; axis <= 3; axis++) {
            if (activeGizmoAxis == axis) glColor3f(1.0f, 1.0f, 0.0f); // Highlight active
            else if (axis == 1) glColor3f(0.6f, 0.0f, 0.0f);
            else if (axis == 2) glColor3f(0.0f, 0.6f, 0.0f);
            else glColor3f(0.0f, 0.0f, 0.6f);

            glBegin(GL_LINE_LOOP);
            for (int i=0; i<36; i++) {
                float a = (float)i * 3.14159f * 2.0f / 36.0f;
                float c = cos(a)*150.0f; float s = sin(a)*150.0f;
                if (axis == 1) glVertex3f(tubPosX, tubPosY + c, tubPosZ + s);
                if (axis == 2) glVertex3f(tubPosX + c, tubPosY, tubPosZ + s);
                if (axis == 3) glVertex3f(tubPosX + c, tubPosY + s, tubPosZ);
            }
            glEnd();
        }
    }
    glLineWidth(1.0f);
    glEnable(GL_DEPTH_TEST);
    glEnable(GL_LIGHTING);

    SwapBuffers(hDC_global);
}
