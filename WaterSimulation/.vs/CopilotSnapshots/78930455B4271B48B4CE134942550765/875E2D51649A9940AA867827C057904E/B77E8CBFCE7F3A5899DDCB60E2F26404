// --- Simulation Constants ---
const int WINDOW_WIDTH = 1024;
const int WINDOW_HEIGHT = 768;
const float GRAVITY = 1500.0f;      // Strength of gravity
const float PARTICLE_RADIUS = 12.0f; // Visual radius of particles
const float DAMPING = 0.5f;         // Energy loss on collision 
const int MAX_PARTICLES = 3000;     // Max limit for performance

// --- Particle Structure ---
struct Particle {
    float x, y, z;     // Position
    float vx, vy, vz;  // Velocity
};

// --- 3D Box for container ---
struct Bounds {
    float minX, maxX;
    float minY, maxY;
    float minZ, maxZ;
};

// --- Simulation State ---
std::vector<Particle> particles;
Bounds container = {-300.0f, 300.0f, -100.0f, 100.0f, -150.0f, 150.0f};

bool isDragging = false;
bool isPouring = false;
POINT lastMousePos;

float cameraPosX = 0.0f;
float cameraPosY = 200.0f;
float cameraPosZ = 800.0f;
float cameraAngleX = 20.0f;
float cameraAngleY = 0.0f;
float cameraDistance = 0.0f; // No longer orbiting center

float tubPosX = 0.0f;
float tubPosY = 0.0f;
float tubPosZ = 0.0f;
float tubAngleX = 0.0f;
float tubAngleY = 0.0f;
float tubAngleZ = 0.0f;

int gizmoMode = 0; // 0=Translate, 1=Rotate
int activeGizmoAxis = 0; // 0=None, 1=X, 2=Y, 3=Z
bool isDraggingGizmo = false;
bool isLooking = false;

float spawnX = 0.0f;
float spawnY = 200.0f;
float spawnZ = 0.0f;

HDC hDC_global = NULL;
HGLRC hRC_global = NULL;

